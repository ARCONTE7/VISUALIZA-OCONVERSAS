<!DOCTYPE html>
<html>
<head>
    <title>Chat com <%= contact.name || contact.phone_number %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #e5ddd5;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .chat-container {
            width: 400px;
            height: 600px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .chat-header {
            background: #075e54;
            color: white;
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .chat-header img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #128C7E;
        }
        .chat-header a {
            color: white;
            text-decoration: none;
            margin-left: auto;
            font-size: 20px;
        }
        .chat-messages {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            background: #e5ddd5;
        }
        .message {
            margin-bottom: 15px;
            max-width: 80%;
            clear: both;
        }
        .message.incoming {
            float: left;
        }
        .message.outgoing {
            float: right;
        }
        .message .bubble {
            padding: 10px 15px;
            border-radius: 20px;
            position: relative;
            word-wrap: break-word;
        }
        .incoming .bubble {
            background: white;
            border-bottom-left-radius: 5px;
        }
        .outgoing .bubble {
            background: #dcf8c6;
            border-bottom-right-radius: 5px;
        }
        .message .time {
            font-size: 11px;
            color: #999;
            margin-top: 5px;
            display: block;
        }
        .outgoing .time {
            text-align: right;
        }
        .back-link {
            display: block;
            padding: 10px;
            background: #f0f0f0;
            text-align: center;
            color: #075e54;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="chat-container">
        <div class="chat-header">
            <img src="https://ui-avatars.com/api/?name=<%= contact.name || 'Cliente' %>&background=128C7E&color=fff&size=40" alt="Avatar">
            <div>
                <h3><%= contact.name || 'Cliente' %></h3>
                <p style="font-size: 12px; opacity: 0.8;"><%= contact.phone_number %></p>
            </div>
            <a href="/conversa/<%= conversation.id %>">✕</a>
        </div>
        
        <div class="chat-messages" id="messages">
            <% messages.forEach(msg => { %>
            <div class="message <%= msg.direction %>">
                <div class="bubble">
                    <%= msg.content %>
                    <span class="time"><%= new Date(msg.created_at).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %></span>
                </div>
            </div>
            <% }) %>
        </div>
        
        <a href="/conversa/<%= conversation.id %>" class="back-link">← Voltar para conversa</a>
    </div>
    
    <script>
        // Auto scroll para o final
        const messagesDiv = document.getElementById('messages');
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    </script>
</body>
</html>
